# ============================================
# APLICAÇÃO
# ============================================
APP_NAME=SaaS Chatbot
# Fallback sem Git/CI. A versão EXIBIDA costuma vir do repositório ou do build:
#   • Local: git describe --tags --always --dirty (ex.: v1.0.0 ou v1.0.0-3-gabc1234)
#   • Docker/CI sem .git: defina BUILD_VERSION no pipeline, ex.:
#       export BUILD_VERSION="$(git describe --tags --always --dirty)"
#   • Ou use GITHUB_SHA / COOLIFY_COMMIT_SHA → vira APP_VERSION+abcdef0
# Health: curl -s https://seu-dominio/health
APP_VERSION=1.0.0
# Opcional em produção (imagem sem pasta .git):
# BUILD_VERSION=v1.0.0-5-gabc1234
DEBUG=True

# ============================================
# SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO)
# ============================================
# ⚠️ IMPORTANTE: Altere estes valores em produção!

# Gere uma SECRET_KEY segura com:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# Algoritmo de criptografia JWT
ALGORITHM=HS256

# Tempo de expiração do token (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credenciais do administrador
# ⚠️ Altere a senha em produção!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================
# Origens permitidas (separadas por vírgula)
# Em produção, liste apenas seus domínios
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Origens permitidas para incorporar o widget via iframe (separadas por vírgula)
# Sites que podem usar <script src="https://seu-chat.com/static/chat-widget.js">
# Deixe vazio para permitir qualquer origem (não recomendado em produção)
WIDGET_ALLOWED_ORIGINS=https://beta.meudominio.com,https://meudominio.com.br

# ============================================
# WHATSAPP
# ============================================
# Número do WhatsApp para suporte (formato internacional, apenas números)
WHATSAPP_NUMBER=5541999999999

# ============================================
# BANCO DE DADOS
# ============================================
# Deixe vazio para usar SQLite padrão (data/saas_chatbot.db)
# Para PostgreSQL: postgresql://user:password@localhost/urania_db
# Para MySQL: mysql://user:password@localhost/urania_db
DATABASE_URL=

# ============================================
# OPENAI API (OBRIGATÓRIO PARA CHAT)
# ============================================
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo OpenAI a usar (gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4o-mini

# ============================================
# UPLOADS
# ============================================
# Diretório de uploads (deixe vazio para usar padrão: uploads/)
UPLOAD_DIR=

# Tamanho máximo de arquivo em bytes (50MB padrão)
MAX_FILE_SIZE=52428800

# Extensões permitidas (separadas por vírgula)
ALLOWED_EXTENSIONS=pdf,gif

# ============================================
# RATE LIMITING
# ============================================
# Habilitar rate limiting
RATE_LIMIT_ENABLED=True

# Número de requisições por minuto por IP (apenas pedidos que entram no contador;
# GET /branding, /chat/status, /static/*, /widget, /files/pdf|gif|image/* e OPTIONS não contam)
RATE_LIMIT_REQUESTS=100

# Atrás de proxy reverso: usar X-Forwarded-For / X-Real-IP (recomendado em produção)
TRUST_FORWARDED_HEADERS=True

# ============================================
# LOGGING
# ============================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Arquivo de log (opcional, deixe vazio para usar stdout)
# LOG_FILE=logs/urania.log

# ============================================
# NOTAS
# ============================================
# O comportamento da rota raiz (/), ativacao/desativacao do widget
# e demais configuracoes do sistema sao gerenciados pelo painel
# de Configuracoes (/settings) e armazenados no banco de dados.
