# ============================================
# APLICAÇÃO
# ============================================
APP_NAME=SaaS Chatbot
APP_VERSION=1.0.0
DEBUG=True

# ============================================
# SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO)
# ============================================
# ⚠️ IMPORTANTE: Altere estes valores em produção!

# Gere uma SECRET_KEY segura com:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# Algoritmo de criptografia JWT
ALGORITHM=HS256

# Tempo de expiração do token (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credenciais do administrador
# ⚠️ Altere a senha em produção!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================
# Origens permitidas (separadas por vírgula)
# Em produção, liste apenas seus domínios
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# BANCO DE DADOS
# ============================================
# Deixe vazio para usar SQLite padrão (data/saas_chatbot.db)
# Para PostgreSQL: postgresql://user:password@localhost/urania_db
# Para MySQL: mysql://user:password@localhost/urania_db
DATABASE_URL=

# ============================================
# OPENAI API (OBRIGATÓRIO PARA CHAT)
# ============================================
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo OpenAI a usar (gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4o-mini

# ============================================
# UPLOADS
# ============================================
# Diretório de uploads (deixe vazio para usar padrão: uploads/)
UPLOAD_DIR=

# Tamanho máximo de arquivo em bytes (50MB padrão)
MAX_FILE_SIZE=52428800

# Extensões permitidas (separadas por vírgula)
ALLOWED_EXTENSIONS=pdf,gif

# ============================================
# RATE LIMITING
# ============================================
# Habilitar rate limiting
RATE_LIMIT_ENABLED=True

# Número de requisições por minuto por IP
RATE_LIMIT_REQUESTS=100

# ============================================
# LOGGING
# ============================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Arquivo de log (opcional, deixe vazio para usar stdout)
# LOG_FILE=logs/urania.log

# ============================================
# ROTA RAIZ
# ============================================
# Comportamento da rota raiz (/)
# Valores: widget, admin, dashboard, login, json ou vazio
# - Em produÃ§Ã£o (DEBUG=False): padrÃ£o Ã© redirecionar para /widget
# - Em desenvolvimento (DEBUG=True): padrÃ£o Ã© retornar JSON
# ROOT_REDIRECT=widget
